  tenant_id       String
  partner_id      String
  // Scope of the share
  scope_type      String    // "tenant" | "branch" | "generator"
  scope_id        String?   // null if scope_type = "tenant"
  percentage      Decimal   @db.Decimal(5,2)  // 0.00 - 100.00
  effective_from  DateTime  @default(now())
  effective_to    DateTime?
  notes           String?
  created_at      DateTime  @default(now())
  partner         Partner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  @@index([tenant_id, scope_type, scope_id])
  @@index([partner_id, effective_from])
  @@map("partner_shares")
}

model PartnerContribution {
  id              String    @id @default(uuid())
  tenant_id       String
  partner_id      String
  amount          Decimal   @db.Decimal(14,2)
  type            String    // "capital" | "loan" | "expense_payment" | "other"
  description     String?
  occurred_at     DateTime  @default(now())
  created_at      DateTime  @default(now())
  partner         Partner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  @@index([tenant_id, occurred_at])
  @@index([partner_id, occurred_at])
  @@map("partner_contributions")
}

model PartnerWithdrawal {
  id                  String    @id @default(uuid())
  tenant_id           String
  partner_id          String
  amount              Decimal   @db.Decimal(14,2)
  type                String    // "profit_distribution" | "personal_withdrawal" | "salary"
  // If linked to a profit distribution
  distribution_id     String?
  period_month        Int?
  period_year         Int?
  description         String?
  occurred_at         DateTime  @default(now())
  created_at          DateTime  @default(now())
  partner             Partner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  distribution        ProfitDistribution? @relation(fields: [distribution_id], references: [id], onDelete: SetNull)
  @@index([tenant_id, occurred_at])
  @@index([partner_id, occurred_at])
  @@index([distribution_id])
  @@map("partner_withdrawals")
}

model ProfitDistribution {
  id              String    @id @default(uuid())
  tenant_id       String
  // Scope (matches what shares filter on)
  scope_type      String    // "tenant" | "branch" | "generator"
  scope_id        String?
  // Period
  period_month    Int
  period_year     Int
  // Snapshot of the math at distribution time (so future changes don't affect history)
  total_revenue   Decimal   @db.Decimal(14,2)
  total_costs     Decimal   @db.Decimal(14,2)
  net_profit      Decimal   @db.Decimal(14,2)
  // Status
  is_finalized    Boolean   @default(false)
  finalized_at    DateTime?
  notes           String?
  created_at      DateTime  @default(now())
  withdrawals     PartnerWithdrawal[]
  @@index([tenant_id, period_year, period_month])
  @@index([scope_type, scope_id])
  @@map("profit_distributions")
}

