generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CompanyRole {
  super_admin
  sales
  support
  accountant
}

enum StaffRole {
  accountant
  collector
  operator
  cashier
}

enum PlanType {
  starter
  pro
  business
  corporate
  fleet
  custom
  trial
  basic
  gold
}

enum ModuleKey {
  subscriber_management
  basic_invoicing
  pos
  reports
  wallet
  whatsapp
  engine_tracking
  daily_brief
  subscriber_app
  ai_reports
  multi_branch
  gps
  iot_monitoring
  fuel_sensor
  temperature_sensor
  operator_app
}

// ─── AMPER INTERNAL ─────────────────────────────────────────

model CompanyUser {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  name       String
  role       CompanyRole @default(support)
  is_active  Boolean     @default(true)
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  @@map("company_users")
}

model Tenant {
  id                    String                @id @default(uuid())
  name                  String
  owner_name            String
  phone                 String                @unique
  email                 String?               @unique
  password              String
  plan                  PlanType              @default(basic)
  is_active             Boolean               @default(true)
  is_trial              Boolean               @default(false)
  trial_ends_at         DateTime?
  trial_subscriber_limit Int                  @default(20)
  subscription_ends_at  DateTime?
  grace_period_ends_at  DateTime?
  is_in_grace_period    Boolean               @default(false)
  locked_at             DateTime?
  custom_max_generators Int?
  custom_max_subscribers Int?
  app_access_code       String?               @unique
  // WhatsApp alerts (for IoT critical events)
  alert_phone           String?               // E.g., "9647801234567"
  alert_provider        String?               // "callmebot" | "wasender" | "twilio"
  alert_api_key         String?
  alerts_enabled        Boolean               @default(false)
  // À-la-carte feature overrides — features force-enabled regardless of plan
  feature_overrides     String[]              @default([])
  // Free trial of higher plan
  trial_plan            String?               // e.g., "business" while on "pro"
  trial_plan_until      DateTime?
  has_used_trial        Boolean               @default(false)
  // APS Fawateer-E (CBI) integration
  aps_enabled           Boolean               @default(false)
  aps_biller_code       String?               // Assigned by CBI
  aps_service_type      String?               // CBI service code (e.g. "30010201")
  aps_billing_prefix    String?               // Prefix for biller_account_no generation (e.g. "01")
  aps_settlement_iban   String?               // Bank account for settlements
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  modules               TenantModule[]
  billing_invoices      BillingInvoice[]
  payments              Payment[]
  support_tickets       SupportTicket[]
  branches              Branch[]
  staff                 Staff[]
  subscribers           Subscriber[]
  online_payments       OnlinePayment[]
  subscriber_app_settings SubscriberAppSettings[]
  pos_devices           PosDevice[]
  discounts             TenantDiscount[]
  staff_salary_configs  StaffSalaryConfig[]
  salary_payments       SalaryPayment[]
  @@map("tenants")
}

model TenantModule {
  id                String    @id @default(uuid())
  tenant_id         String
  module_key        ModuleKey
  is_active         Boolean   @default(true)
  add_on_price      Decimal?  @db.Decimal(12,2)
  added_outside_plan Boolean  @default(false)
  activated_at      DateTime  @default(now())
  deactivated_at    DateTime?
  tenant            Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  @@unique([tenant_id, module_key])
  @@map("tenant_modules")
}

model BillingInvoice {
  id              String    @id @default(uuid())
  tenant_id       String
  amount          Decimal   @db.Decimal(12,2)
  discount_amount Decimal   @default(0) @db.Decimal(12,2)
  final_amount    Decimal   @db.Decimal(12,2)
  discount_id     String?
  plan            PlanType
  period_start    DateTime
  period_end      DateTime
  is_paid         Boolean   @default(false)
  paid_at         DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenant_id], references: [id])
  @@index([tenant_id, is_paid])
  @@map("billing_invoices")
}

model Payment {
  id           String   @id @default(uuid())
  tenant_id    String
  invoice_id   String?
  amount       Decimal  @db.Decimal(12,2)
  method       String
  reference    String?
  notes        String?
  recorded_by  String?
  created_at   DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
  @@map("payments")
}

model SupportTicket {
  id          String        @id @default(uuid())
  tenant_id   String?
  title       String
  body        String
  status      String        @default("open")
  priority    String        @default("normal")
  assigned_to String?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  tenant      Tenant?       @relation(fields: [tenant_id], references: [id])
  replies     TicketReply[]
  @@map("support_tickets")
}

model TicketReply {
  id         String        @id @default(uuid())
  ticket_id  String
  author_id  String
  author_type String
  body       String
  created_at DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticket_id], references: [id])
  @@map("ticket_replies")
}

model StoreProduct {
  id            String       @id @default(uuid())
  name_ar       String
  name_en       String?
  description   String?
  price_usd     Decimal      @db.Decimal(10,2)
  category      String
  stock         Int          @default(0)
  is_active     Boolean      @default(true)
  sort_order    Int          @default(0)
  discount_pct  Decimal?     @db.Decimal(5,2)
  discount_ends_at DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  orders        StoreOrder[]
  @@map("store_products")
}

model StoreOrder {
  id          String       @id @default(uuid())
  product_id  String
  tenant_id   String?
  name        String
  phone       String
  governorate String?
  notes       String?
  status      String       @default("pending")
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  product     StoreProduct @relation(fields: [product_id], references: [id])
  @@index([status, created_at])
  @@map("store_orders")
}

model TrialRequest {
  id              String    @id @default(uuid())
  name            String
  phone           String
  governorate     String?
  generator_count Int       @default(1)
  subscriber_count Int?     @default(0)
  plan_interest   String?   // "starter" | "pro" | "business" | "corporate" | "fleet"
  billing_period  String?   // "monthly" | "quarterly" | "biannual" | "annual"
  notes           String?
  source          String    @default("landing")
  status          String    @default("new")
  contacted_at    DateTime?
  created_at      DateTime  @default(now())
  @@index([status, created_at])
  @@map("trial_requests")
}

model ContactInquiry {
  id           String    @id @default(uuid())
  name         String
  phone        String
  email        String?
  governorate  String?
  inquiry_type String    @default("general")  // general | sales | support | partnership | demo
  message      String
  status       String    @default("new")
  responded_at DateTime?
  created_at   DateTime  @default(now())
  @@index([status, created_at])
  @@map("contact_inquiries")
}

model PlanChangeLog {
  id          String   @id @default(uuid())
  tenant_id   String
  changed_by  String
  change_type String
  from_plan   PlanType?
  to_plan     PlanType?
  notes       String?
  created_at  DateTime @default(now())
  @@index([tenant_id, created_at])
  @@map("plan_change_logs")
}

// ─── BRANCH & GENERATOR ──────────────────────────────────────

model Branch {
  id           String   @id @default(uuid())
  tenant_id    String
  name         String
  address      String?
  governorate  String?
  province_key String?
  district_key String?
  whatsapp_number String?
  gps_lat      Decimal?  @db.Decimal(10,8)
  gps_lng      Decimal?  @db.Decimal(11,8)
  furatpay_merchant_id      String?
  furatpay_api_key          String?
  furatpay_secret_key       String?
  furatpay_is_sandbox       Boolean  @default(true)
  aps_merchant_id           String?
  aps_access_code           String?
  aps_sha_request_phrase    String?
  aps_sha_response_phrase   String?
  aps_is_sandbox            Boolean  @default(true)
  aps_enabled               Boolean  @default(false)
  active_gateway            String   @default("none")
  zaincash_phone            String?
  is_online_payment_enabled Boolean  @default(false)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  generators         Generator[]
  staff              Staff[]
  subscribers        Subscriber[]
  invoices           Invoice[]
  expenses           Expense[]
  operation_logs     OperationLog[]
  normal_cut_logs    NormalCutLog[]
  notifications      Notification[]
  delivery_records   DeliveryRecord[]
  monthly_pricing    MonthlyPricing[]
  offline_queue      OfflineSyncQueue[]
  loss_reports       LossReport[]
  marketing_messages MarketingMessage[]
  upgrade_requests   UpgradeRequest[]
  meter_readings     MeterReading[]
  collector_reports  CollectorDailyReport[]
  pos_devices        PosDevice[]
  ai_reports         AiReport[]
  operator_shifts    OperatorShift[]
  collector_shifts   CollectorShift[]
  gps_logs           StaffGpsLog[]
  subscriber_discounts SubscriberDiscount[]
  collector_discount_requests CollectorDiscountRequest[]
  alleys             Alley[]
  invoice_generation_logs InvoiceGenerationLog[]
  @@index([tenant_id, is_active])
  @@map("branches")
}

model Generator {
  id                    String    @id @default(uuid())
  branch_id             String
  name                  String
  is_active             Boolean   @default(true)
  run_status            Boolean   @default(false)
  manual_override_allowed Boolean @default(false)
  owner_is_collector    Boolean   @default(false)
  fuel_level_pct        Float?
  tank_full_dist_cm     Float?
  tank_empty_dist_cm    Float?
  tank_capacity_liters  Float?    // Total tank capacity for fuel theft cost estimation
  last_fuel_update      DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  branch                Branch    @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  engines               Engine[]
  subscribers           Subscriber[]
  iot_devices           IotDevice[]
  manual_overrides      ManualOverrideLog[]
  raspberry_devices     RaspberryDevice[]
  subscriber_app_settings SubscriberAppSettings?
  operator_shifts       OperatorShift[]
  operator_schedules    OperatorSchedule[]
  @@index([branch_id])
  @@map("generators")
}

model Engine {
  id                  String    @id @default(uuid())
  generator_id        String
  name                String
  model               String?
  oil_change_hours    Int       @default(250)
  air_filter_hours    Int       @default(500)
  full_service_hours  Int       @default(1000)
  runtime_hours       Decimal   @default(0) @db.Decimal(10,2)
  hours_at_last_oil   Decimal   @default(0) @db.Decimal(10,2)
  hours_at_last_filter Decimal  @default(0) @db.Decimal(10,2)
  hours_at_last_service Decimal @default(0) @db.Decimal(10,2)
  last_oil_change_at  DateTime?
  ds18b20_address     String?
  gold_ct_pin         Int?
  normal_ct_pin       Int?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  generator           Generator @relation(fields: [generator_id], references: [id], onDelete: Cascade)
  fuel_logs           FuelLog[]
  temperature_logs    TemperatureLog[]
  iot_devices         IotDeviceEngine[]
  maintenance_logs    MaintenanceLog[]
  @@map("engines")
}

model MaintenanceLog {
  id            String   @id @default(uuid())
  tenant_id     String
  engine_id     String
  type          String   // "oil_change" | "air_filter" | "full_service" | "custom"
  description   String?
  hours_at_service Decimal @db.Decimal(10,2)
  cost          Decimal? @db.Decimal(12,2)
  performed_by  String?
  performed_at  DateTime @default(now())
  engine        Engine   @relation(fields: [engine_id], references: [id], onDelete: Cascade)
  @@index([engine_id, performed_at])
  @@index([tenant_id, performed_at])
  @@map("maintenance_logs")
}


// ─── SUBSCRIBER ───────────────────────────────────────────────

model Alley {
  id          String   @id @default(uuid())
  branch_id   String
  tenant_id   String
  name        String
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  branch      Branch   @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  subscribers Subscriber[]
  @@unique([branch_id, name])
  @@index([branch_id, sort_order])
  @@map("alleys")
}

model Subscriber {
  id                  String    @id @default(uuid())
  branch_id           String
  generator_id        String
  tenant_id           String
  serial_number       String
  name                String
  phone               String?
  whatsapp            String?
  address             String?
  alley               String?
  alley_id            String?
  governorate         String?
  province_key        String?
  district_key        String?
  amperage            Decimal   @db.Decimal(8,2)
  subscription_type   String    @default("normal")
  total_debt          Decimal   @default(0) @db.Decimal(12,2)
  access_code         String?   @unique
  meter_number        String?
  // APS Fawateer-E (CBI) integration: globally unique billing number used at ATM/POS
  biller_account_no   String?   @unique
  needs_attention     Boolean   @default(false)
  is_active           Boolean   @default(true)
  deleted_at          DateTime?
  notes               String?
  gps_lat             Decimal?  @db.Decimal(10,8)
  gps_lng             Decimal?  @db.Decimal(11,8)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  branch              Branch    @relation(fields: [branch_id], references: [id])
  generator           Generator @relation(fields: [generator_id], references: [id])
  tenant              Tenant    @relation(fields: [tenant_id], references: [id])
  alley_ref           Alley?    @relation(fields: [alley_id], references: [id])
  invoices            Invoice[]
  meter_readings      MeterReading[]
  pos_transactions    PosTransaction[]
  discounts           SubscriberDiscount[]
  discount_requests   CollectorDiscountRequest[]
  collector_call_requests CollectorCallRequest[]
  @@unique([branch_id, serial_number])
  @@index([tenant_id, is_active])
  @@index([alley_id])
  @@map("subscribers")
}

model MonthlyPricing {
  id                  String   @id @default(uuid())
  branch_id           String
  billing_type        String   @default("fixed")
  price_per_amp_normal Decimal @db.Decimal(10,2)
  price_per_amp_gold  Decimal  @db.Decimal(10,2)
  hourly_rate_normal  Decimal? @db.Decimal(10,4)
  hourly_rate_gold    Decimal? @db.Decimal(10,4)
  billing_mode        String   @default("prepaid")
  effective_from      DateTime @default(now())
  created_at          DateTime @default(now())
  branch              Branch   @relation(fields: [branch_id], references: [id])
  @@index([branch_id, effective_from])
  @@map("monthly_pricing")
}

model Invoice {
  id               String   @id @default(uuid())
  subscriber_id    String
  branch_id        String
  tenant_id        String
  billing_month    Int
  billing_year     Int
  base_amount      Decimal  @default(0) @db.Decimal(12,2)
  discount_amount  Decimal  @default(0) @db.Decimal(12,2)
  discount_type    String?
  discount_value   Decimal? @db.Decimal(10,2)
  discount_reason  String?
  total_amount_due Decimal  @db.Decimal(12,2)
  amount_paid      Decimal  @default(0) @db.Decimal(12,2)
  previous_debt    Decimal  @default(0) @db.Decimal(12,2)
  is_fully_paid    Boolean  @default(false)
  is_reversed      Boolean  @default(false)
  reversed_at      DateTime?
  reversed_by      String?
  invoice_number   String?
  payment_method   String?
  online_payment_id String?
  // APS Fawateer-E linkage (one of these set when paid via APS channel)
  aps_bank_trx_id  String?  @unique
  aps_joebpps_trx  String?
  collector_id     String?
  received_by_owner Boolean @default(false)
  device_id        String?
  notes            String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  updated_by       String?
  subscriber       Subscriber @relation(fields: [subscriber_id], references: [id], onDelete: Restrict)
  branch           Branch   @relation(fields: [branch_id], references: [id])
  @@unique([subscriber_id, billing_month, billing_year])
  @@index([branch_id, billing_month, billing_year])
  @@index([is_fully_paid, branch_id])
  @@map("invoices")
}

model InvoiceGenerationLog {
  id            String    @id @default(uuid())
  branch_id     String
  tenant_id     String
  generated_at  DateTime  @default(now())
  invoice_count Int
  debt_count    Int       @default(0)
  generated_by  String
  billing_month Int
  billing_year  Int
  is_reversed   Boolean   @default(false)
  reversed_at   DateTime?
  branch        Branch    @relation(fields: [branch_id], references: [id])
  @@index([branch_id, generated_at])
  @@map("invoice_generation_logs")
}

model MeterReading {
  id            String   @id @default(uuid())
  subscriber_id String
  branch_id     String
  staff_id      String?
  reading_value Decimal  @db.Decimal(12,2)
  previous_reading Decimal @default(0) @db.Decimal(12,2)
  units_consumed Decimal @default(0) @db.Decimal(12,2)
  reading_date  DateTime @default(now())
  notes         String?
  subscriber    Subscriber @relation(fields: [subscriber_id], references: [id])
  branch        Branch   @relation(fields: [branch_id], references: [id])
  @@index([subscriber_id, reading_date])
  @@map("meter_readings")
}

// ─── STAFF ───────────────────────────────────────────────────

model Staff {
  id              String              @id @default(uuid())
  generator_id    String?
  branch_id       String
  tenant_id       String
  name            String
  role            StaffRole
  phone           String?
  email           String?
  pin             String?
  password        String?
  is_active       Boolean             @default(true)
  is_owner_acting Boolean             @default(false)
  can_collect     Boolean             @default(false)
  can_operate     Boolean             @default(false)
  can_send_announcements Boolean      @default(false)
  can_send_urgent Boolean             @default(false)
  can_view_phones        Boolean      @default(true)
  can_view_others_debt   Boolean      @default(false)
  can_view_wallet        Boolean      @default(true)
  can_view_salary        Boolean      @default(true)
  can_send_whatsapp      Boolean      @default(true)
  can_add_expenses       Boolean      @default(true)
  can_check_in           Boolean      @default(true)
  track_location         Boolean      @default(true)
  photo_url       String?
  device_id       String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  updated_by      String?
  branch          Branch              @relation(fields: [branch_id], references: [id])
  tenant          Tenant              @relation(fields: [tenant_id], references: [id])
  branch_access         StaffBranchAccess[]
  daily_reports         CollectorDailyReport[]
  pos_devices           PosDevice[]
  pos_transactions      PosTransaction[]
  operator_shifts       OperatorShift[]
  operator_schedules    OperatorSchedule[]
  operator_permission   OperatorPermission?
  collector_shifts      CollectorShift[]
  collector_permission  CollectorPermission?
  gps_logs              StaffGpsLog[]
  discount_requests     CollectorDiscountRequest[]
  devices               StaffDevice[]
  salary_config         StaffSalaryConfig?
  salary_payments       SalaryPayment[]
  @@unique([phone, tenant_id])
  @@index([branch_id, role])
  @@map("staff")
}

model StaffDevice {
  id         String   @id @default(uuid())
  staff_id   String
  fcm_token  String
  platform   String   @default("android")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  staff      Staff    @relation(fields: [staff_id], references: [id])
  @@unique([staff_id, fcm_token])
  @@index([staff_id])
  @@map("staff_devices")
}

model StaffBranchAccess {
  id         String  @id @default(uuid())
  staff_id   String
  branch_id  String
  can_edit   Boolean @default(false)
  staff      Staff   @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  @@unique([staff_id, branch_id])
  @@map("staff_branch_access")
}

model CollectorWallet {
  id              String   @id @default(uuid())
  staff_id        String   @unique
  branch_id       String
  tenant_id       String
  total_collected Decimal  @default(0) @db.Decimal(12,2)
  total_delivered Decimal  @default(0) @db.Decimal(12,2)
  balance         Decimal  @default(0) @db.Decimal(12,2)
  last_updated    DateTime @default(now())
  @@map("collector_wallets")
}

model DeliveryRecord {
  id                String    @id @default(uuid())
  branch_id         String
  from_staff_id     String
  to_staff_id       String?
  tenant_id         String?
  received_by_owner Boolean   @default(false)
  amount            Decimal   @db.Decimal(12,2)
  payment_type      String    @default("cash")
  notes             String?
  is_confirmed      Boolean   @default(false)
  confirmed_at      DateTime?
  confirmed_by      String?
  delivered_at      DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  device_id         String?
  branch            Branch    @relation(fields: [branch_id], references: [id])
  @@index([branch_id, from_staff_id])
  @@index([from_staff_id, delivered_at])
  @@map("delivery_records")
}

// ─── IOT ─────────────────────────────────────────────────────

model IotDevice {
  id                  String    @id @default(uuid())
  generator_id        String
  // New: tenant + branch for multi-engine support
  tenant_id           String?
  branch_id           String?
  name                String?
  // Auth
  device_token        String    @unique @default(uuid())
  device_type         String    @default("esp32")
  // QR Pairing (new)
  pairing_code        String?   @unique
  pairing_expires_at  DateTime?
  paired_at           DateTime?
  // Status
  is_online           Boolean   @default(false)
  is_active           Boolean   @default(true)
  last_seen           DateTime?
  last_heartbeat      DateTime?
  last_telemetry      DateTime?
  firmware            String?
  // Metadata
  sensors_config      Json?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt @default(now())
  // Relations
  generator           Generator @relation(fields: [generator_id], references: [id])
  engines             IotDeviceEngine[]
  telemetry_records   IotTelemetry[]
  fuel_events         FuelEvent[]
  @@index([tenant_id, branch_id])
  @@index([pairing_code])
  @@map("iot_devices")
}

model IotDeviceEngine {
  id          String    @id @default(uuid())
  device_id   String
  engine_id   String
  temp_pin    Int?
  fuel_pin    Int?
  current_pin Int?
  created_at  DateTime  @default(now())
  device      IotDevice @relation(fields: [device_id], references: [id], onDelete: Cascade)
  engine      Engine    @relation(fields: [engine_id], references: [id], onDelete: Cascade)
  @@unique([device_id, engine_id])
  @@map("iot_device_engines")
}

model IotTelemetry {
  id            String    @id @default(uuid())
  device_id     String
  engine_id     String?
  temperature_c Float?
  fuel_pct      Float?
  current_a     Float?
  voltage_v     Float?
  oil_status    String?
  run_status    Boolean?
  recorded_at   DateTime  @default(now())
  device        IotDevice @relation(fields: [device_id], references: [id], onDelete: Cascade)
  @@index([device_id, recorded_at])
  @@index([engine_id, recorded_at])
  @@map("iot_telemetry")
}

// Hourly snapshot of fuel consumption — used for L/h + profitability calculations
model FuelConsumption {
  id              String   @id @default(uuid())
  tenant_id       String
  branch_id       String
  generator_id    String
  device_id       String?
  // Window
  window_start    DateTime
  window_end      DateTime @default(now())
  // Measurements
  fuel_pct_start  Float
  fuel_pct_end    Float
  liters_consumed Float    // Estimated using tank_capacity
  cost_iqd        Decimal? @db.Decimal(12,2)
  // Engine load during window
  avg_current_a   Float?
  runtime_minutes Int      // How many minutes engine was running in this window
  liters_per_hour Float?
  @@index([generator_id, window_end])
  @@index([tenant_id, window_end])
  @@map("fuel_consumption")
}

model VoltageEvent {
  id            String   @id @default(uuid())
  tenant_id     String
  branch_id     String
  generator_id  String
  device_id     String?
  type          String   // "low_warning" | "low_critical" | "high_warning" | "high_critical"
  voltage       Float    // Measured voltage at the time
  threshold     Float    // The threshold that was crossed
  duration_sec  Int?     // How long the event lasted (filled when resolved)
  detected_at   DateTime @default(now())
  resolved_at   DateTime?
  is_resolved   Boolean  @default(false)
  notes         String?
  @@index([tenant_id, branch_id, detected_at])
  @@index([generator_id, detected_at])
  @@map("voltage_events")
}

model OverloadEvent {
  id                String   @id @default(uuid())
  tenant_id         String
  branch_id         String
  generator_id      String
  device_id         String?
  measured_amps     Float    // Actual current draw
  subscribed_amps   Float    // Sum of subscribers' amperage
  excess_amps       Float    // measured - subscribed
  excess_pct        Float    // (excess / subscribed) * 100
  active_subs_count Int      // Number of active subscribers at the time
  detected_at       DateTime @default(now())
  is_resolved       Boolean  @default(false)
  notes             String?
  @@index([tenant_id, branch_id, detected_at])
  @@index([generator_id, detected_at])
  @@map("overload_events")
}

// ─── APS FAWATEER-E (CBI) ────────────────────────────────────

// Raw log of every payment notification received from APS.
// Used for audit, idempotency, and reconciliation against APS settlement reports.
model ApsTransaction {
  id              String    @id @default(uuid())
  tenant_id       String
  // From the notification
  joebpps_trx     String    @unique  // APS unique trx id
  bank_trx_id     String                // Issuing bank's trx id
  bank_code       String                // Acquiring bank
  billing_no      String                // Maps to subscriber.biller_account_no
  bill_no         String
  service_type    String
  paid_amount     Decimal   @db.Decimal(14,3)
  due_amount      Decimal   @db.Decimal(14,3)
  fees_amount     Decimal   @default(0) @db.Decimal(14,3)
  fees_on_biller  Boolean   @default(false)
  process_date    DateTime
  stmt_date       DateTime  @db.Date
  access_channel  String                // ATM, POS, MOB, WEB, etc.
  payment_method  String                // ACTDEB, CCDEB, etc.
  payment_type    String?               // POSTPAID | PREPAID
  // Linkage to our internal records
  subscriber_id   String?
  invoice_id      String?
  status          String    @default("received")  // received | applied | failed | reversed
  error_message   String?
  raw_payload     Json?     // Full incoming XML/JSON for audit
  received_at     DateTime  @default(now())
  applied_at      DateTime?
  @@index([tenant_id, received_at])
  @@index([billing_no])
  @@index([bank_trx_id])
  @@index([status])
  @@map("aps_transactions")
}

// Periodic settlements (when APS transfers collected funds to the tenant's bank account)
model ApsSettlement {
  id              String    @id @default(uuid())
  tenant_id       String
  period_month    Int
  period_year     Int
  total_collected Decimal   @db.Decimal(14,2)
  fees_amount     Decimal   @db.Decimal(14,2)
  net_amount      Decimal   @db.Decimal(14,2)
  trx_count       Int       @default(0)
  is_settled      Boolean   @default(false)
  settled_at      DateTime?
  notes           String?
  created_at      DateTime  @default(now())
  @@unique([tenant_id, period_year, period_month])
  @@map("aps_settlements")
}

model FuelEvent {
  id            String    @id @default(uuid())
  tenant_id     String
  branch_id     String
  device_id     String
  generator_id  String?
  type          String    // "theft_suspected" | "refill" | "leak_suspected"
  fuel_before   Float     // Percentage before the event
  fuel_after    Float     // Percentage after the event
  delta_pct     Float     // fuel_after - fuel_before (negative = drop)
  liters_est    Float?    // Estimated liters (if tank capacity known)
  cost_est_iqd  Decimal?  @db.Decimal(12,2)
  occurred_at   DateTime  @default(now())
  is_resolved   Boolean   @default(false)
  notes         String?
  device        IotDevice @relation(fields: [device_id], references: [id], onDelete: Cascade)
  @@index([tenant_id, branch_id, occurred_at])
  @@index([type, occurred_at])
  @@map("fuel_events")
}

